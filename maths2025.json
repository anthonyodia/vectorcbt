    { "id": 19, "question": "Cylinder r=8, h=14. Find Curved Surface Area. (π = 22/7)", "options": [{"optionId": "A", "text": "352 cm²"}, {"optionId": "B", "text": "704 cm²"}, {"optionId": "C", "text": "1408 cm²"}, {"optionId": "D", "text": "800 cm²"}], "answer": "B", "explanation": "CSA = 2πrh = 2 * 22/7 * 8 * 14 = 704.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
