    { "id": 1, "question": "Write 0.036481 in three significant figures and express the answer in standard form.", "options": [{"optionId": "A", "text": "3.64 x 10^-2"}, {"optionId": "B", "text": "3.65 x 10^-2"}, {"optionId": "C", "text": "3.65 x 10^-3"}, {"optionId": "D", "text": "3.648 x 10^-2"}], "answer": "B", "explanation": "0.036481 rounded to 3 sig figs is 0.0365. In standard form, move the decimal 2 places: 3.65 x 10^-2.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 2, "question": "Given that 21ₓ = 14₁₀, find the value of x.", "options": [{"optionId": "A", "text": "5"}, {"optionId": "B", "text": "6"}, {"optionId": "C", "text": "6.5"}, {"optionId": "D", "text": "13"}], "answer": "C", "explanation": "2(x) + 1 = 14. 2x = 13. x = 6.5.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 3, "question": "Simplify √200 − √72.", "options": [{"optionId": "A", "text": "4√2"}, {"optionId": "B", "text": "2√2"}, {"optionId": "C", "text": "√128"}, {"optionId": "D", "text": "8√2"}], "answer": "A", "explanation": "√200 = 10√2 and √72 = 6√2. 10√2 - 6√2 = 4√2.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 4, "question": "If 2log(1 − √x / √x) = 0, find the value of x.", "options": [{"optionId": "A", "text": "1"}, {"optionId": "B", "text": "0.5"}, {"optionId": "C", "text": "2"}, {"optionId": "D", "text": "0.25"}], "answer": "D", "explanation": "log((1-√x)/√x) = 0 means (1-√x)/√x = 1. 1-√x = √x. 1 = 2√x. √x = 0.5. x = 0.25.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 5, "question": "Factorize 3 − 2x − x².", "options": [{"optionId": "A", "text": "(x+3)(x-1)"}, {"optionId": "B", "text": "(3+x)(1-x)"}, {"optionId": "C", "text": "(3-x)(1+x)"}, {"optionId": "D", "text": "-(x-3)(x+1)"}], "answer": "B", "explanation": "Factoring -x^2 - 2x + 3 gives (3+x)(1-x).", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 6, "question": "A variable P varies inversely as the square of Q. If P = 5 when Q = 6, find Q when P = 1.8.", "options": [{"optionId": "A", "text": "8"}, {"optionId": "B", "text": "9"}, {"optionId": "C", "text": "10"}, {"optionId": "D", "text": "12"}], "answer": "C", "explanation": "P = k/Q^2. 5 = k/36 -> k=180. 1.8 = 180/Q^2 -> Q^2 = 100 -> Q = 10.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 7, "question": "M = {x : 2 ≤ x ≤ 6} and N = {x : 4 ≤ x ≤ 8} for ξ = {1...10}. Find M ∩ N′.", "options": [{"optionId": "A", "text": "{2, 3}"}, {"optionId": "B", "text": "{2, 3, 4}"}, {"optionId": "C", "text": "{4, 5, 6}"}, {"optionId": "D", "text": "{7, 8, 9, 10}"}], "answer": "A", "explanation": "N' = {1, 2, 3, 9, 10}. M = {2, 3, 4, 5, 6}. M ∩ N' = {2, 3}.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 8, "question": "Represent: 'The sun(p) is shining if and only if the weather(q) is warm'.", "options": [{"optionId": "A", "text": "p ∧ q"}, {"optionId": "B", "text": "p ∨ q"}, {"optionId": "C", "text": "p → q"}, {"optionId": "D", "text": "q ↔ p"}], "answer": "D", "explanation": "'If and only if' is represented by the biconditional ↔ symbol.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
