    { "id": 12, "question": "Given x + y = 1 and x + 3y = 5, find x² + 4xy + 3y².", "options": [{"optionId": "A", "text": "5"}, {"optionId": "B", "text": "6"}, {"optionId": "C", "text": "8"}, {"optionId": "D", "text": "10"}], "answer": "A", "explanation": "x^2 + 4xy + 3y^2 = (x+y)(x+3y). Given (1)(5) = 5.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 13, "question": "Given that log₄16 = logᵧ36, find the value of y.", "options": [{"optionId": "A", "text": "2"}, {"optionId": "B", "text": "4"}, {"optionId": "C", "text": "6"}, {"optionId": "D", "text": "12"}], "answer": "C", "explanation": "log4(16) = 2. log_y(36) = 2 means y^2 = 36. y = 6.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 14, "question": "John sold an article for ₦105,000 at a loss of 4%. Find the cost price.", "options": [{"optionId": "A", "text": "₦109,375"}, {"optionId": "B", "text": "₦110,000"}, {"optionId": "C", "text": "₦115,000"}, {"optionId": "D", "text": "₦100,000"}], "answer": "A", "explanation": "96% of CP = 105,000. CP = 105,000 / 0.96 = 109,375.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 15, "question": "Population increases 2% yearly. After 2 yrs it is 83,232. Find original population.", "options": [{"optionId": "A", "text": "78,000"}, {"optionId": "B", "text": "80,000"}, {"optionId": "C", "text": "81,000"}, {"optionId": "D", "text": "82,000"}], "answer": "B", "explanation": "P(1.02)^2 = 83,232. P = 83,232 / 1.0404 = 80,000.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 16, "question": "3rd and 9th terms of an AP are 9 and −27. Find the 5th term.", "options": [{"optionId": "A", "text": "-3"}, {"optionId": "B", "text": "3"}, {"optionId": "C", "text": "-9"}, {"optionId": "D", "text": "0"}], "answer": "A", "explanation": "a+2d=9, a+8d=-27 -> 6d=-36 -> d=-6. a=21. 5th term = 21 + 4(-6) = -3.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
    { "id": 17, "question": "Article sold for $500 gives 8% profit. Price for 16% profit?", "options": [{"optionId": "A", "text": "$540"}, {"optionId": "B", "text": "$537.04"}, {"optionId": "C", "text": "$580"}, {"optionId": "D", "text": "$600"}], "answer": "B", "explanation": "CP = 500/1.08. New Price = (500/1.08) * 1.16 = 537.04.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
