    { "id": 10, "question": "Simplify 2√3 + √27.", "options": [{"optionId": "A", "text": "5√3"}, {"optionId": "B", "text": "3√3"}, {"optionId": "C", "text": "√30"}, {"optionId": "D", "text": "6√3"}], "answer": "A", "explanation": "√27 = 3√3. 2√3 + 3√3 = 5√3.", "image": null, "sectionName": "Mathematics", "sectionId": 1 },
